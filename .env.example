# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=50

# PostgreSQL Configuration
POSTGRES_URL=postgresql://user:password@localhost:5432/voice_system

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET=call-recordings
S3_REGION=us-east-1

# Telephony Providers
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_WEBHOOK_URL=https://your-domain.com/webhook
EXOTEL_API_KEY=your_exotel_key
EXOTEL_API_TOKEN=your_exotel_token

# Google Cloud APIs
GOOGLE_CLOUD_PROJECT=your_project_id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials.json

# OpenAI API
OPENAI_API_KEY=your_openai_key
OPENAI_MODEL=gpt-4

# Latency Budgets (milliseconds)
LATENCY_VAD_DETECTION=200
LATENCY_STT_FINAL=400
LATENCY_LLM_FIRST_TOKEN=800
LATENCY_TTS_FIRST_CHUNK=300
LATENCY_TOTAL_TARGET=1800

# Retry Policy
RETRY_NO_ANSWER_MAX_ATTEMPTS=3
RETRY_NO_ANSWER_INITIAL_DELAY_MIN=120
RETRY_DROPPED_MAX_ATTEMPTS=3
RETRY_DROPPED_INITIAL_DELAY_MIN=30

# Feature Flags
ENABLE_DASHBOARD=true
ENABLE_BARGE_IN=true
ENABLE_AUDIO_RECORDING=true
ENABLE_PREFERENCE_LEARNING=true
